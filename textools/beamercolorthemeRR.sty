\setbeamercolor{structure}{fg=maincolor}
\setbeamercolor{palette primary}{fg=white,bg=maincolor!70}
\setbeamercolor{palette secondary}{fg=white,bg=maincolor!100}
\setbeamercolor{palette tertiary}{fg=white,bg=maincolor!100}
\setbeamercolor{palette quaternary}{fg=white,bg=maincolor!100}

\setbeamercolor{titlelike}{bg=white, fg=maincolor}

\setbeamercolor{block title}{bg=grey1,fg=blue1}
\setbeamercolor{block title alerted}{use=alerted text,fg=myblue,bg=alerted text.fg!75!bg}
\setbeamercolor{block title example}{use=example text,fg=myblue,bg=example text.fg!75!bg}

\setbeamercolor{block body}{parent=normal text,use=block title,bg=block title.bg!25!bg}
\setbeamercolor{block body alerted}{parent=normal text,use=block title alerted,bg=block title alerted.bg!25!bg}
\setbeamercolor{block body example}{parent=normal text,use=block title example,bg=block title example.bg!25!bg}

\setbeamercolor{sidebar}{bg=maincolor!70}
  
\setbeamercolor{palette sidebar primary}{fg=myblue}
\setbeamercolor{palette sidebar secondary}{fg=myblue!75}
\setbeamercolor{palette sidebar tertiary}{fg=myblue!75}
\setbeamercolor{palette sidebar quaternary}{fg=myblue}

